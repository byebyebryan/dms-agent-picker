{
  "$schema": "https://danklinux.com/schemas/plugin.json",
  "id": "agentSessions",
  "name": "Agent Sessions",
  "description": "Open local and SSH Codex and Claude Code sessions",
  "version": "0.3.0",
  "author": "Bryan Bai",
  "icon": "terminal",
  "type": "launcher",
  "capabilities": ["launcher", "command-execution"],
  "component": "./AgentSessions.qml",
  "settings": "./AgentSessionsSettings.qml",
  "trigger": "agent:",
  "permissions": ["process", "settings_read", "settings_write"],
  "dependencies": ["codex", "ghostty", "python", "ssh", "tmux"]
}
